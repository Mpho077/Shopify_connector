<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_shopify" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.shopify.connector</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Shopify Auto-Invoice" data-key="corvex_shopify_connector">
                    <h2>Shopify Auto-Invoice</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="shopify_auto_create_invoice"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="shopify_auto_create_invoice"/>
                                <div class="text-muted">
                                    Automatically create and post an invoice when a Shopify order is confirmed.
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box"
                             invisible="not shopify_auto_create_invoice">
                            <div class="o_setting_left_pane">
                                <field name="shopify_auto_register_payment"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="shopify_auto_register_payment"/>
                                <div class="text-muted">
                                    Automatically register a payment on the invoice.
                                </div>
                                <div class="mt8" invisible="not shopify_auto_register_payment">
                                    <label for="shopify_payment_journal_id" string="Payment Journal"/>
                                    <field name="shopify_payment_journal_id" class="o_light_label"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
