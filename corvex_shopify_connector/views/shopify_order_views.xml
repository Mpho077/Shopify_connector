<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Inject is_pickup into sale.order form (invisible, for Studio/filters) -->
    <record id="shopify_sale_order_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.shopify.is_pickup</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <field name="is_pickup" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- Inject is_pickup into stock.picking form (invisible, for Studio/filters) -->
    <record id="shopify_stock_picking_form_inherit" model="ir.ui.view">
        <field name="name">stock.picking.form.shopify.is_pickup</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <field name="is_pickup" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
