<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================================ -->
    <!--          ERROR NOTIFICATION CONFIGURATION                    -->
    <!-- ============================================================ -->

    <!-- Tree View -->
    <record id="shopify_error_notification_view_tree" model="ir.ui.view">
        <field name="name">shopify.error.notification.tree</field>
        <field name="model">shopify.error.notification</field>
        <field name="arch" type="xml">
            <list>
                <field name="shopify_instance_id"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="notify_on_error"/>
                <field name="notify_on_warning"/>
                <field name="resend_interval_minutes"/>
                <field name="last_notified"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="shopify_error_notification_view_form" model="ir.ui.view">
        <field name="name">shopify.error.notification.form</field>
        <field name="model">shopify.error.notification</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="NOTIFICATION SETTINGS">
                        <group>
                            <field name="shopify_instance_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="notify_on_error"/>
                            <field name="notify_on_warning"/>
                            <field name="resend_interval_minutes"/>
                            <field name="last_notified"/>
                        </group>
                    </group>
                    <group string="USERS TO NOTIFY">
                        <div class="alert alert-info" role="alert">
                            <strong>How it works:</strong>
                            <ul class="mb-0">
                                <li>A cron runs every <strong>15 minutes</strong> scanning for failed order imports, sync errors, and stuck queues.</li>
                                <li>Selected users receive <strong>email</strong> and <strong>Odoo notifications</strong> with details of every issue found.</li>
                                <li>Notifications are <strong>re-sent</strong> every <em>N</em> minutes (configured above) until resolved.</li>
                                <li>Nothing goes unnoticed — errors will keep pinging until fixed.</li>
                            </ul>
                        </div>
                        <field name="user_ids" nolabel="1" widget="many2many_tags"
                            placeholder="Add users who should be notified..."
                            options="{'no_create': True}"
                            colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_shopify_error_notification" model="ir.actions.act_window">
        <field name="name">Error Notification Settings</field>
        <field name="res_model">shopify.error.notification</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure error notifications for your Shopify instances
            </p>
            <p>
                Select which users should receive emails and Odoo notifications
                when sync errors or warnings occur. Notifications are automatically
                re-sent until the error is acknowledged.
            </p>
        </field>
    </record>
</odoo>
